<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Soma Blanks — Premium Oversized Tees</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-white text-gray-900 min-h-screen">

  <!-- Header -->
  <header class="border-b border-gray-100 sticky top-0 bg-white/95 backdrop-blur z-40">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold tracking-widest text-gray-900">SOMA BLANKS</h1>
        <p class="text-xs text-gray-400 tracking-wide mt-0.5">Premium oversized tees</p>
      </div>
    </div>
  </header>

  <!-- Content -->
  <div class="max-w-6xl mx-auto px-6 py-12">

    <% for (const [category, products] of Object.entries(byCategory)) { %>
      <% if (products.length === 0) continue; %>
      <section class="mb-16">
        <div class="mb-8">
          <h2 class="text-xl font-bold text-gray-900"><%= category %></h2>
          <div class="w-12 h-0.5 bg-gray-900 mt-2"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% products.forEach(product => { %>
            <%
              const totalStock = sizes.reduce((sum, s) => sum + (product.stock[s] || 0), 0);
            %>
            <div class="group bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-md transition-shadow duration-300">
              <!-- Color swatch -->
              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-full border-2 border-gray-100 shadow-inner"
                  style="background-color: <%= product.color %>;"
                ></div>
                <div>
                  <h3 class="font-semibold text-gray-900"><%= product.sku %></h3>
                  <p class="text-xs text-gray-400"><%= product.price %> zł</p>
                </div>
              </div>

              <!-- Size badges -->
              <div class="flex flex-wrap gap-1.5 mb-5">
                <% sizes.forEach(size => { %>
                  <% const qty = product.stock[size] || 0; %>
                  <% if (qty >= 2) { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-50 text-green-700 border border-green-200">
                      <%= size %>
                    </span>
                  <% } else if (qty === 1) { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200" title="Ostatnia sztuka">
                      <%= size %> <span class="text-amber-500">!</span>
                    </span>
                  <% } else { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-50 text-gray-300 border border-gray-100 line-through">
                      <%= size %>
                    </span>
                  <% } %>
                <% }) %>
              </div>

              <!-- Availability summary -->
              <% if (totalStock === 0) { %>
                <p class="text-xs text-gray-400 mb-4">Chwilowo niedostępne</p>
              <% } else { %>
                <p class="text-xs text-gray-400 mb-4">
                  <span class="text-green-600 font-medium"><%= totalStock %> szt.</span> dostępnych
                </p>
              <% } %>

              <!-- Size buttons for cart -->
              <% if (totalStock === 0) { %>
                <button disabled class="w-full py-2.5 px-4 rounded-xl text-sm font-medium bg-gray-50 text-gray-300 cursor-not-allowed">Brak w magazynie</button>
              <% } else { %>
                <div class="flex flex-wrap gap-1.5">
                  <% sizes.forEach(size => { %>
                    <% const qty = product.stock[size] || 0; %>
                    <% if (qty > 0) { %>
                      <button
                        class="add-to-cart px-3 py-1.5 rounded-lg text-xs font-medium border-2 border-gray-900 text-gray-900 hover:bg-gray-900 hover:text-white transition-colors duration-150"
                        data-product-id="<%= product.id %>"
                        data-sku="<%= product.sku %>"
                        data-category="<%= product.category %>"
                        data-size="<%= size %>"
                        data-price="<%= product.price %>"
                        data-max-qty="<%= qty %>"
                      ><%= size %></button>
                    <% } else { %>
                      <span class="px-3 py-1.5 rounded-lg text-xs font-medium bg-gray-50 text-gray-300 border-2 border-gray-100 line-through"><%= size %></span>
                    <% } %>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>
  </div>

  <!-- Footer -->
  <footer class="border-t border-gray-100 mt-8">
    <div class="max-w-6xl mx-auto px-6 py-6 text-center">
      <p class="text-gray-400 text-sm">© Soma Blanks 2025</p>
    </div>
  </footer>

  <!-- Floating cart button -->
  <div id="cartBtn" class="hidden fixed bottom-6 right-6 z-50">
    <a href="/koszyk" class="flex items-center gap-2 bg-gray-900 text-white px-5 py-3 rounded-full shadow-lg hover:bg-gray-700 transition font-medium text-sm">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-9H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
      Koszyk (<span id="cartCount">0</span>)
    </a>
  </div>

  <script>
    const CART_KEY = 'soma_cart';
    function getCart() { try { return JSON.parse(localStorage.getItem(CART_KEY) || '[]'); } catch { return []; } }
    function saveCart(c) { localStorage.setItem(CART_KEY, JSON.stringify(c)); }
    function updateCartBtn() {
      const total = getCart().reduce((s, i) => s + i.quantity, 0);
      document.getElementById('cartCount').textContent = total;
      document.getElementById('cartBtn').classList.toggle('hidden', total === 0);
    }
    document.addEventListener('click', function(e) {
      const btn = e.target.closest('.add-to-cart');
      if (!btn) return;
      const cart = getCart();
      const { productId, sku, category, size, price, maxQty } = btn.dataset;
      const existing = cart.find(i => i.productId === productId && i.size === size);
      if (existing) {
        if (existing.quantity < parseInt(maxQty)) existing.quantity++;
      } else {
        cart.push({ productId, sku, category, size, quantity: 1, price: parseFloat(price), maxQty: parseInt(maxQty) });
      }
      saveCart(cart);
      updateCartBtn();
      // Flash feedback on button
      btn.textContent = '✓';
      btn.classList.add('bg-gray-900', 'text-white');
      setTimeout(() => { btn.textContent = size; btn.classList.remove('bg-gray-900', 'text-white'); }, 800);
    });
    updateCartBtn();
  </script>
</body>
</html>
