<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Soma Blanks — Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    #sidebar { transition: transform 0.25s ease; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">

  <!-- Mobile top bar -->
  <header class="lg:hidden fixed top-0 left-0 right-0 z-30 bg-[#111] flex items-center justify-between px-4 py-3">
    <div>
      <span class="text-white text-lg font-bold tracking-widest">SOMA</span>
      <span class="text-gray-500 text-xs ml-2">admin</span>
    </div>
    <button onclick="toggleSidebar()" class="text-gray-400 hover:text-white p-1">
      <svg id="hamburgerIcon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </header>

  <!-- Sidebar overlay (mobile) -->
  <div id="overlay" onclick="closeSidebar()" class="hidden fixed inset-0 z-20 bg-black/50 lg:hidden"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed top-0 left-0 z-20 h-full w-56 bg-[#111] flex flex-col -translate-x-full lg:translate-x-0 transition-transform">
    <div class="px-6 py-6 border-b border-white/10">
      <span class="text-white text-xl font-bold tracking-widest">SOMA</span>
      <p class="text-gray-500 text-xs mt-0.5">blanks admin</p>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-white/10 text-white text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <a href="/admin/magazyn" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        Magazyn
      </a>
      <a href="/admin/zamowienia" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Zamówienia
      </a>
      <a href="/admin/dostawa" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-400 hover:bg-white/5 hover:text-white text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
        Dostawa
      </a>
    </nav>
    <div class="px-3 pb-6">
      <a href="/wyloguj" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-500 hover:text-red-400 text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Wyloguj
      </a>
    </div>
  </aside>

  <!-- Main content -->
  <main class="lg:ml-56 pt-14 lg:pt-0 pb-20 lg:pb-0 min-h-screen">
    <div class="p-4 lg:p-8">

      <div class="mb-6">
        <h1 class="text-xl lg:text-2xl font-bold text-gray-900">Dashboard</h1>
        <p class="text-gray-500 text-sm mt-1">Przegląd stanu magazynu i zamówień</p>
      </div>

      <!-- Metrics cards — 2 cols mobile, 3 cols desktop -->
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-4 mb-6">
        <div class="bg-white rounded-xl p-4 lg:p-5 shadow-sm border border-gray-100">
          <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center mb-2">
            <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <div class="text-2xl lg:text-3xl font-bold text-gray-900"><%= totalStock %></div>
          <div class="text-gray-500 text-xs lg:text-sm mt-1">Stan magazynu</div>
        </div>
        <div class="bg-white rounded-xl p-4 lg:p-5 shadow-sm border border-gray-100">
          <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center mb-2">
            <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          </div>
          <div class="text-2xl lg:text-3xl font-bold <%= pendingCarts && pendingCarts.length > 0 ? 'text-amber-500' : 'text-blue-600' %>"><%= newOrders %></div>
          <div class="text-gray-500 text-xs lg:text-sm mt-1">Nowe zamówienia<% if (pendingCarts && pendingCarts.length > 0) { %> <span class="text-amber-500 font-semibold">(<%= pendingCarts.length %> koszyków)</span><% } %></div>
        </div>
        <div class="bg-white rounded-xl p-4 lg:p-5 shadow-sm border border-gray-100">
          <div class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center mb-2">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          </div>
          <div class="text-2xl lg:text-3xl font-bold text-purple-600"><%= confirmedOrders %></div>
          <div class="text-gray-500 text-xs lg:text-sm mt-1">Do opłacenia</div>
        </div>
        <div class="bg-white rounded-xl p-4 lg:p-5 shadow-sm border border-gray-100">
          <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center mb-2">
            <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
          </div>
          <div class="text-2xl lg:text-3xl font-bold text-amber-600"><%= paidOrders %></div>
          <div class="text-gray-500 text-xs lg:text-sm mt-1">Do wysyłki</div>
        </div>
        <div class="bg-white rounded-xl p-4 lg:p-5 shadow-sm border border-gray-100">
          <div class="w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center mb-2">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="text-2xl lg:text-3xl font-bold text-green-600"><%= revenue.toFixed(0) %> zł</div>
          <div class="text-gray-500 text-xs lg:text-sm mt-1">Przychód</div>
        </div>
        <div class="bg-white rounded-xl p-4 lg:p-5 shadow-sm border border-gray-100">
          <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center mb-2">
            <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <div class="text-2xl lg:text-3xl font-bold text-red-500"><%= lowStock %></div>
          <div class="text-gray-500 text-xs lg:text-sm mt-1">Niski stan</div>
        </div>
      </div>

      <% if (pendingCarts && pendingCarts.length > 0) { %>
      <div class="mb-6">
        <h2 class="text-base font-semibold text-gray-800 mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Oczekujące zamówienia (<%= pendingCarts.length %>)
        </h2>
        <div class="space-y-3">
          <% pendingCarts.forEach(cart => { %>
          <div class="bg-white rounded-xl border-2 border-amber-200 shadow-sm p-4" id="cart-<%= cart.token %>">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-900"><%= cart.customer_name %></p>
                <p class="text-xs text-gray-500 mt-0.5"><%= cart.customer_contact %></p>
                <div class="mt-2 space-y-1">
                  <% cart.items.forEach(item => { %>
                    <p class="text-sm text-gray-700">• <%= item.sku %> <%= item.size %> × <%= item.quantity %> szt. — <%= (item.price * item.quantity).toFixed(0) %> zł</p>
                  <% }) %>
                </div>
                <p class="text-sm font-semibold text-gray-900 mt-2">Razem: <%= cart.total.toFixed(0) %> zł</p>
                <% if (cart.notes) { %><p class="text-xs text-gray-400 mt-1">Uwagi: <%= cart.notes %></p><% } %>
              </div>
              <div class="flex flex-col gap-2 shrink-0">
                <button onclick="acceptCart('<%= cart.token %>')" class="bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-700 transition">✓ Akceptuj</button>
                <button onclick="rejectCart('<%= cart.token %>')" class="border border-red-200 text-red-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-50 transition">✕ Odrzuć</button>
                <a href="/zamowienie/<%= cart.token %>" target="_blank" class="text-center text-xs text-gray-400 hover:text-gray-600">Zobacz →</a>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-6">

        <!-- Recent orders -->
        <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-4 lg:px-5 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-semibold text-gray-800 text-sm lg:text-base">Ostatnie zamówienia</h2>
            <a href="/admin/zamowienia" class="text-sm text-gray-500 hover:text-gray-800 transition">Zobacz →</a>
          </div>
          <% if (recentOrders.length === 0) { %>
            <p class="px-4 py-6 text-center text-gray-400 text-sm">Brak zamówień</p>
          <% } else { %>
            <!-- Mobile: card list -->
            <div class="lg:hidden divide-y divide-gray-50">
              <% recentOrders.forEach(order => { %>
                <div class="px-4 py-3 flex items-center justify-between">
                  <div>
                    <p class="font-medium text-gray-800 text-sm"><%= order.customer_name %></p>
                    <p class="text-xs text-gray-400 mt-0.5"><%= order.sku %> · <%= order.size %></p>
                  </div>
                  <div class="text-right">
                    <% if (order.status === 'new') { %>
                      <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Nowe</span>
                    <% } else if (order.status === 'confirmed') { %>
                      <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">Potwierdzone</span>
                    <% } else if (order.status === 'paid') { %>
                      <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Opłacone</span>
                    <% } else if (order.status === 'shipped') { %>
                      <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Wysłane</span>
                    <% } else { %>
                      <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Anulowane</span>
                    <% } %>
                    <p class="text-xs text-gray-400 mt-1"><%= formatDate(order.created_at) %></p>
                  </div>
                </div>
              <% }) %>
            </div>
            <!-- Desktop: table -->
            <div class="hidden lg:block overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                    <th class="px-4 py-3 text-left">Klient</th>
                    <th class="px-4 py-3 text-left">Produkt</th>
                    <th class="px-4 py-3 text-left">Rozmiar</th>
                    <th class="px-4 py-3 text-left">Status</th>
                    <th class="px-4 py-3 text-left">Data</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <% recentOrders.forEach(order => { %>
                    <tr class="hover:bg-gray-50">
                      <td class="px-4 py-3 font-medium text-gray-800"><%= order.customer_name %></td>
                      <td class="px-4 py-3 text-gray-600"><%= order.sku %></td>
                      <td class="px-4 py-3 text-gray-600"><%= order.size %></td>
                      <td class="px-4 py-3">
                        <% if (order.status === 'new') { %>
                          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Nowe</span>
                        <% } else if (order.status === 'confirmed') { %>
                          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">Potwierdzone</span>
                        <% } else if (order.status === 'paid') { %>
                          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">Opłacone</span>
                        <% } else if (order.status === 'shipped') { %>
                          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Wysłane</span>
                        <% } else { %>
                          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">Anulowane</span>
                        <% } %>
                      </td>
                      <td class="px-4 py-3 text-gray-500"><%= formatDate(order.created_at) %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <!-- Right column -->
        <div class="space-y-4 lg:space-y-6">
          <!-- Best colors -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 lg:p-5">
            <h2 class="font-semibold text-gray-800 mb-3 text-sm lg:text-base">Najpopularniejsze kolory</h2>
            <% if (bestColors.length === 0) { %>
              <p class="text-gray-400 text-sm">Brak danych</p>
            <% } else { %>
              <div class="space-y-3">
                <% bestColors.forEach((item, idx) => { %>
                  <div class="flex items-center gap-3">
                    <span class="text-gray-400 text-sm font-medium w-4"><%= idx + 1 %></span>
                    <div class="w-5 h-5 rounded-full border border-gray-200 flex-shrink-0" style="background-color: <%= colorMap[item.sku] || '#999' %>"></div>
                    <span class="text-sm text-gray-700 flex-1"><%= item.sku %></span>
                    <span class="text-sm font-semibold text-gray-900"><%= item.cnt %> szt.</span>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>

          <!-- Low stock -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 lg:p-5">
            <h2 class="font-semibold text-gray-800 mb-3 text-sm lg:text-base flex items-center gap-2">
              <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              Niski stan (1 szt.)
            </h2>
            <% if (lowStockItems.length === 0) { %>
              <p class="text-green-600 text-sm">Wszystko OK</p>
            <% } else { %>
              <div class="space-y-2 max-h-48 overflow-y-auto">
                <% lowStockItems.forEach(item => { %>
                  <div class="flex items-center justify-between text-sm">
                    <div class="flex items-center gap-2">
                      <div class="w-3 h-3 rounded-full border border-gray-200 flex-shrink-0" style="background-color: <%= colorMap[item.sku] || '#999' %>"></div>
                      <span class="text-gray-700"><%= item.sku %></span>
                      <span class="text-gray-400 text-xs"><%= item.size %></span>
                    </div>
                    <span class="font-semibold text-amber-600 text-xs">1 szt.</span>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- Mobile bottom navigation -->
  <nav class="lg:hidden fixed bottom-0 left-0 right-0 z-30 bg-[#111] border-t border-white/10 flex">
    <a href="/admin" class="flex-1 flex flex-col items-center py-2.5 text-white">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      <span class="text-xs mt-1 font-medium">Dashboard</span>
    </a>
    <a href="/admin/magazyn" class="flex-1 flex flex-col items-center py-2.5 text-gray-500">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      <span class="text-xs mt-1">Magazyn</span>
    </a>
    <a href="/admin/zamowienia" class="flex-1 flex flex-col items-center py-2.5 text-gray-500">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      <span class="text-xs mt-1">Zamówienia</span>
    </a>
    <a href="/admin/dostawa" class="flex-1 flex flex-col items-center py-2.5 text-gray-500">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
      <span class="text-xs mt-1">Dostawa</span>
    </a>
  </nav>

  <script>
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('overlay');
      const isOpen = !sidebar.classList.contains('-translate-x-full');
      if (isOpen) {
        closeSidebar();
      } else {
        sidebar.classList.remove('-translate-x-full');
        overlay.classList.remove('hidden');
      }
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.add('-translate-x-full');
      document.getElementById('overlay').classList.add('hidden');
    }

    async function acceptCart(token) {
      if (!confirm('Zaakceptować zamówienie? Stan magazynu zostanie zaktualizowany.')) return;
      const r = await fetch('/admin/zamowienia/akceptuj-koszyk', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({token}) });
      if ((await r.json()).success) { document.getElementById('cart-'+token).remove(); location.reload(); }
    }
    async function rejectCart(token) {
      if (!confirm('Odrzucić zamówienie?')) return;
      const r = await fetch('/admin/zamowienia/odrzuc-koszyk', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({token}) });
      if ((await r.json()).success) { document.getElementById('cart-'+token).remove(); }
    }
  </script>

</body>
</html>
